# Whitelist mode: keep the repo to the shipped plugins + their distribution/dev scaffolding.
# Nothing runtime, local, or personal should ever land here.
/*

# --- Marketplace manifest (root) ---
!/.claude-plugin/

# --- Shipped plugins (harness kit + devlog companion) ---
!/plugins/

# --- Distribution / maintenance tooling ---
!/README.md
!/LICENSE
!/CHANGELOG.md
!/.gitignore
!/.gitattributes

# --- Dev harness for developing THIS repo (curated only) ---
!/.claude/
/.claude/*
!/.claude/CLAUDE.md
!/.claude/devlog/
!/.claude/skills/

# Never track even inside whitelisted dirs
.credentials.json
settings.local.json
*.bak*
*.log
__pycache__/
.pytest_cache/
.DS_Store
